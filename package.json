{
  "name": "eve-settings-manager",
  "version": "0.0.1",
  "main": "dist-electron/main/index.js",
  "description": "EVE Online local setting files manager",
  "author": "Nick Ning",
  "license": "MIT",
  "private": true,
  "keywords": [
    "electron",
    "rollup",
    "vite",
    "vue3",
    "vue"
  ],
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "reset-fixtures": "node scripts/reset-fixtures.mjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.9",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "electron-store": "^11.0.2",
    "element-plus": "^2.13.6",
    "pinia": "^3.0.4",
    "vue-i18n": "^11.3.0"
  }
}
